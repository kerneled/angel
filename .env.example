# === LLM Providers ===
LLM_PROVIDER=claude                     # claude | gemini
LLM_FALLBACK=gemini                     # automatic failover target
ANTHROPIC_API_KEY=your_key
GEMINI_API_KEY=your_key

# === Audio ML ===
HF_MODEL_AUDIO=facebook/wav2vec2-base
HF_CACHE_DIR=/app/models

# === Capture Intervals ===
FRAME_INTERVAL_MS=2500                  # camera capture interval
AUDIO_CHUNK_MS=3000                     # mic chunk interval

# === Upload ===
MAX_UPLOAD_SIZE_MB=100

# === Storage ===
SESSION_DB_PATH=./data/sessions.db

# === Cloudflare ===
CLOUDFLARE_TUNNEL_URL=https://dogsense.yourdomain.com

# === API ===
API_HOST=0.0.0.0
API_PORT=8000

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
